# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local
.env.*.local

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/

# ── Data folders — mounted as volumes, not baked into image ───────────────────
input_files/
processed_files/
failed_files/
logs/

# ── Docker files themselves ───────────────────────────────────────────────────
docker-compose*.yml
Dockerfile*

# ── Docs ──────────────────────────────────────────────────────────────────────
*.md
*.txt
!requirements.txt
